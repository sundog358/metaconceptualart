{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/prepublic.mjs && next build",
  "redirects": [
    {
      "source": "/data/linked-art/:slug.json",
      "destination": "/data/linked-art/:slug",
      "statusCode": 301
    },
    {
      "source": "/data/linked-art/site-as-artwork",
      "has": [{ "type": "header", "key": "accept", "value": ".*text/html.*" }],
      "destination": "/",
      "statusCode": 303
    },
    {
      "source": "/data/linked-art/eight-sentences",
      "has": [{ "type": "header", "key": "accept", "value": ".*text/html.*" }],
      "destination": "/artworks#work-eight-sentences",
      "statusCode": 303
    },
    {
      "source": "/data/linked-art/construction-museum",
      "has": [{ "type": "header", "key": "accept", "value": ".*text/html.*" }],
      "destination": "/artworks#work-construction-museum",
      "statusCode": 303
    }
  ],
  "rewrites": [
    {
      "source": "/data/linked-art/:slug",
      "destination": "/data/linked-art/:slug.json"
    }
  ],
  "headers": [
    {
      "source": "/data/linked-art/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/ld+json;profile=\"https://linked.art/ns/v1/linked-art.json\""
        },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Accept, Content-Type" },
        { "key": "Vary", "value": "Accept" }
      ]
    },
    {
      "source": "/data/iiif/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/ld+json;profile=\"http://iiif.io/api/presentation/3/context.json\""
        },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/artworks/(.*)/opengraph-image",
      "headers": [{ "key": "Content-Type", "value": "image/png" }]
    }
  ]
}

_:b0_r9b4 crm:P190_has_symbolic_content "work:movement-record";
    crm:P2_has_type aat:300312355;
    a crm:E42_Identifier.
_:b0_r9b5 crm:P190_has_symbolic_content "The Movement Record turns the claim for Metaconceptual Art into a citable textual work and a machine-readable evidence surface. It distinguishes local validity from external canonization while pointing to Linked Art, Wikidata, Getty vocabularies, IIIF, schema.org, and the git-derived Activity Stream.";
    crm:P2_has_type aat:300435416;
    a crm:E33_Linguistic_Object.

    a crm:E12_Production;
    rdfs:label "Designation of the auction engagement as artwork".
_:b0_r1b1 crm:P82a_begin_of_the_begin "2009-01-01T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    crm:P82b_end_of_the_end "2009-12-31T23:59:59Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a crm:E52_Time-Span;
    rdfs:label "2009".
_:b0_r1b2 crm:P190_has_symbolic_content "The artistic act is the designation, by Sun & Rain Works, of its auction engagement as a work — not the auction's ordinary business, which was carried out by Sotheby's. The designation is an assertion by the artist.";
    crm:P2_has_type aat:300435416;
    a crm:E33_Linguistic_Object.
_:b0_r1b3 a crm:E33_Linguistic_Object;
    rdfs:label "Artwork page";
    la:digitally_carried_by _:b0_r1b4.
_:b0_r1b4 <http://purl.org/dc/elements/1.1/format> "text/html";
    a <http://www.ics.forth.gr/isl/CRMdig/D1_Digital_Object>;
    rdfs:label "Metaconceptual Art — The Auction as Artwork";
    la:access_point <https://www.metaconceptualart.com/artworks#work-auction-as-artwork>.
_:b0_r1b5 crm:P190_has_symbolic_content "The Auction as Artwork";
    crm:P2_has_type aat:300404670;
    crm:P72_has_language aat:300388277;
    a crm:E33_E41_Linguistic_Appellation.
_:b0_r1b6 crm:P190_has_symbolic_content "work:auction-as-artwork";
    crm:P2_has_type aat:300312355;
    a crm:E42_Identifier.
_:b0_r1b7 crm:P190_has_symbolic_content "A Metaconceptual Art work that Sun & Rain Works designates in connection with the Sotheby's Photographs auction of 2009 (sale N08533, New York), at which Sun & Rain Works consigned an Ansel Adams photograph, 'San Francisco from Twin Peaks' (lot 16). Following the logic of the readymade, Sun & Rain Works frames its engagement with that public institutional event — its mechanism of value, authority, and sale — as the material of a conceptual work. This is a designation asserted by the artist and made explicit over time; it is not a publicly witnessed live-creation event, and the Sotheby's catalogue does not name Sun & Rain Works. Two associated works accompany the gesture: the website www.wtfisart.com and WTF is Ansel Adams.";
    crm:P2_has_type aat:300435416;
    a crm:E33_Linguistic_Object.
_:b0_r1b8 crm:P190_has_symbolic_content "Documentation reported by Sun & Rain Works includes 2008 correspondence with Sotheby's Photographs, the public catalogue lot, photographs, receipts, and related records; these evidence the artist identity and the consignment. The fuller archive remains held by the studio pending redaction and rights review. This record makes no adjudicated historical-priority claim and asserts no comparison with, or precedence over, any later artist or event absent separately published evidence.";
    crm:P2_has_type aat:300435416;
    a crm:E33_Linguistic_Object.
_:b0_r2b0 crm:P190_has_symbolic_content "Metaconceptual Art — Collection";
    crm:P2_has_type aat:300404670;
    crm:P72_has_language aat:300388277;
    a crm:E33_E41_Linguistic_Appellation.
_:b0_r2b1 crm:P190_has_symbolic_content "set:collection";
    crm:P2_has_type aat:300312355;
    a crm:E42_Identifier.
_:b0_r2b2 crm:P190_has_symbolic_content "The museum is not a building; it is a set of relations. This Set gathers the works on view and the citable Movement Record as members so the collection can be read and queried as linked data. Membership is declared on each object via member_of.";
    crm:P2_has_type aat:300435416;
    a crm:E33_Linguistic_Object.
_:b0_r2b3 crm:P14_carried_out_by mca:sun-and-rain-works;
    crm:P4_has_time-span _:b0_r2b4;
    a crm:E65_Creation;
    rdfs:label "Assembly of the Metaconceptual Art collection".
_:b0_r2b4 crm:P82a_begin_of_the_begin "2026-01-01T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    crm:P82b_end_of_the_end "2026-12-31T23:59:59Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a crm:E52_Time-Span;
    rdfs:label "2026".
_:b0_r3b0 crm:P190_has_symbolic_content "Metaconceptual Art";
    crm:P2_has_type aat:300404670;
    crm:P72_has_language aat:300388277;
    a crm:E33_E41_Linguistic_Appellation.
_:b0_r3b1 crm:P190_has_symbolic_content "concept:metaconceptual-art";
    crm:P2_has_type aat:300312355;
    a crm:E42_Identifier.
_:b0_r3b2 crm:P190_has_symbolic_content "Art that treats art, its institutions, markets, archives, and viewers as the material of the work. A self-defined movement concept created by Sun & Rain Works in 2007, extending conceptual art into the system that makes art legible. Its public Record argues credibility through genealogy, defined principles, works on view, machine-readable standards, external alignment, and provenance over time.";
    crm:P2_has_type aat:300435416;
    a crm:E33_Linguistic_Object.
_:b0_r3b3 crm:P14_carried_out_by mca:sun-and-rain-works;
    crm:P15_was_influenced_by aat:300047869, aat:300055863, aat:300264827, aat:300391330, aat:300419940, wd:Q18692990, wd:Q6041145;
    crm:P4_has_time-span _:b0_r3b4;
    a crm:E65_Creation;
    rdfs:label "Definition of Metaconceptual Art as a movement concept".
_:b0_r3b4 crm:P82a_begin_of_the_begin "2007-01-01T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    crm:P82b_end_of_the_end "2007-12-31T23:59:59Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a crm:E52_Time-Span;
    rdfs:label "2007".

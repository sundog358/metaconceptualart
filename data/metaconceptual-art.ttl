    la:digitally_carried_by _:b0_r4b1.
_:b0_r4b1 <http://purl.org/dc/elements/1.1/format> "text/html";
    a <http://www.ics.forth.gr/isl/CRMdig/D1_Digital_Object>;
    rdfs:label "Metaconceptual Art — Artworks";
    la:access_point <https://www.metaconceptualart.com/artworks#work-construction-museum>.
_:b0_r4b2 crm:P190_has_symbolic_content "Construction of the Museum as Concept";
    crm:P2_has_type aat:300404670;
    crm:P72_has_language aat:300388277;
    a crm:E33_E41_Linguistic_Appellation.
_:b0_r4b3 crm:P190_has_symbolic_content "work:construction-museum";
    crm:P2_has_type aat:300312355;
    a crm:E42_Identifier.
_:b0_r4b4 crm:P190_has_symbolic_content "An image study in which the museum appears inside the artwork as something still being built. Institutional authority is shown as architecture, ornament, labor, scaffolding, and frame.";
    crm:P2_has_type aat:300435416;
    a crm:E33_Linguistic_Object.

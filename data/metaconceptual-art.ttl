mca:movement-record crm:P104_is_subject_to _:b0_r9b0;
    crm:P129_is_about mca:concept-metaconceptual-art;
    crm:P129i_is_subject_of _:b0_r9b1;
    crm:P190_has_symbolic_content "A linked-open-data record arguing that Metaconceptual Art is a natural, credible, and valid movement through genealogy, defined principles, works on view, machine-readable standards, external alignment, and provenance over time.";
    crm:P1_is_identified_by _:b0_r9b3, _:b0_r9b4;
    crm:P2_has_type aat:300026087, aat:300435443;
    crm:P67i_is_referred_to_by _:b0_r9b5;
    crm:P94i_was_created_by _:b0_r9b6;

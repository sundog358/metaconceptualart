_:b0_r11b2 crm:P82a_begin_of_the_begin "2009-01-01T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    crm:P82b_end_of_the_end "2009-12-31T23:59:59Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a crm:E52_Time-Span;
    rdfs:label "2009".
_:b0_r11b3 crm:P190_has_symbolic_content "Sun & Rain Works' engagement with Sotheby's Photographs, 2009 (sale N08533): the consignment of an Ansel Adams photograph, 'San Francisco from Twin Peaks' (lot 16), and the artist's designation of that engagement — together with the associated website www.wtfisart.com — as conceptual works. Sun & Rain Works frames the primary work as The Auction as Artwork, with two associated works, WTF is Ansel Adams and www.wtfisart.com. These designations are assertions by the artist, made explicit over time; they are not publicly witnessed live-creation events, and the Sotheby's catalogue does not name Sun & Rain Works.";
    crm:P2_has_type aat:300435416;
    a crm:E33_Linguistic_Object.
_:b0_r12b0 crm:P82a_begin_of_the_begin "2026-01-01T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

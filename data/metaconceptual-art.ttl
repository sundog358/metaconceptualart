    a crm:E52_Time-Span;
    rdfs:label "2026".
_:b0_r12b1 crm:P190_has_symbolic_content "Public linked-data publication of selected Metaconceptual Art records in 2026. This publication makes the movement and selected works machine-readable on the open web; it is not the creation date of Sun & Rain Works, the movement, or all portfolio works.";
    crm:P2_has_type aat:300435416;
    a crm:E33_Linguistic_Object.

    crm:P2_has_type aat:300312355;
    a crm:E42_Identifier.
_:b0_r14b2 crm:P82a_begin_of_the_begin "2009-01-01T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    crm:P82b_end_of_the_end "2009-12-31T23:59:59Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a crm:E52_Time-Span;
    rdfs:label "2009".
_:b0_r14b3 crm:P190_has_symbolic_content "The public Sotheby's Photographs auction (sale N08533), New York, 2009, carried out by Sotheby's, at which Sun & Rain Works consigned an Ansel Adams photograph, 'San Francisco from Twin Peaks' (lot 16). Sun & Rain Works designates its engagement with this auction as the material of the conceptual work The Auction as Artwork. This record names the real-world event and cites the public catalogue; it does not assert that Sotheby's authored, endorsed, or participated in the artwork, and the catalogue does not name Sun & Rain Works.";
    crm:P2_has_type aat:300435416;
    a crm:E33_Linguistic_Object.
_:b0_r14b4 a crm:E53_Place;
    rdfs:label "Sotheby's, New York".
_:b0_r15b0 crm:P190_has_symbolic_content "Sotheby's";
    crm:P2_has_type aat:300404670;
    crm:P72_has_language aat:300388277;
    a crm:E33_E41_Linguistic_Appellation.
_:b0_r15b1 crm:P190_has_symbolic_content "agent:sothebys";
    crm:P2_has_type aat:300312355;
    a crm:E42_Identifier.
_:b0_r15b2 crm:P190_has_symbolic_content "https://www.sothebys.com/";
    crm:P2_has_type aat:300404626;
    a crm:E42_Identifier.
_:b0_r15b3 crm:P190_has_symbolic_content "International auction house founded in 1744. Named here only as the institution that carried out the Sotheby's Photographs auction (sale N08533), New York, 2009 — the public event that Sun & Rain Works designates as the material of the conceptual work The Auction as Artwork. Recording Sotheby's as the auction's host asserts no partnership, endorsement, or claim against Sotheby's.";
    crm:P2_has_type aat:300435416;
    a crm:E33_Linguistic_Object.
_:b0_r16b0 crm:P190_has_symbolic_content "Sun & Rain Works";
    crm:P2_has_type aat:300404670;

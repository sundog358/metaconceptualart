  "referred_to_by": [
    {
      "type": "LinguisticObject",
      "content": "A Metaconceptual Art performance work enacted live during Sotheby's Photographs auction on March 30, 2009. Made as a companion to the born-digital work www.wtfisart.com, it turns the auction itself — its lots, its authority, and the name of Ansel Adams as a canonical photographer — into the material of the work.",
      "classified_as": [
        {
          "id": "http://vocab.getty.edu/aat/300435416",
          "type": "Type",
          "_label": "description"
        }
      ]
    },
    {
      "type": "LinguisticObject",
      "content": "Sun & Rain Works reports that photographs, metadata, emails, auction catalogue material, receipts, and related records document the live performance. The public Linked Art record names the work and the event while the fuller evidence archive remains held by the studio pending redaction and rights review.",
      "classified_as": [
        {
